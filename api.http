### ==============================================
### AUTH ENDPOINTS
### ==============================================
### Sign in
POST {{baseUrl}}/auth/signin
Content-Type: application/json

{
  "email": "dispatcher@example.com",
  "password": "Password123!"
}

### Refresh tokens
POST {{baseUrl}}/auth/refresh
Authorization: Bearer {{refreshToken}}
Content-Type: application/json

### Get profile
GET {{baseUrl}}/auth/profile
Authorization: Bearer {{accessToken}}

### Update profile
PATCH {{baseUrl}}/auth/profile
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "fullName": "John Doe Updated",
  "phoneNumber": "+1234567891"
}

### Change password
POST {{baseUrl}}/auth/change-password
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "currentPassword": "Password123!",
  "newPassword": "NewPassword123!"
}

### Forgot password
POST {{baseUrl}}/auth/forgot-password
Content-Type: application/json

{
  "email": "john.doe@example.com"
}

### Reset password
POST {{baseUrl}}/auth/reset-password
Content-Type: application/json

{
  "token": "reset-token-here",
  "newPassword": "NewPassword123!"
}

### Get all sessions
GET {{baseUrl}}/auth/sessions
Authorization: Bearer {{accessToken}}

### Delete a session
DELETE {{baseUrl}}/auth/sessions/{{sessionId}}
Authorization: Bearer {{accessToken}}

### Delete all sessions
DELETE {{baseUrl}}/auth/sessions
Authorization: Bearer {{accessToken}}

### Logout
POST {{baseUrl}}/auth/logout
Authorization: Bearer {{accessToken}}


### ==============================================
### USERS ENDPOINTS
### ==============================================

### Register/Create User (Standard)
POST {{baseUrl}}/users
Content-Type: application/json

{
  "fullName": "Standard User",
  "email": "user@example.com",
  "username": "standarduser",
  "password": "Password123!",
  "phoneNumber": "+1234567890",
  "role": "user",
  "isActive": true
}

### Register/Create Officer
POST {{baseUrl}}/users
Content-Type: application/json

{
  "fullName": "Police Officer",
  "email": "officer@example.com",
  "username": "policeofficer",
  "password": "Password123!",
  "phoneNumber": "+1234567891",
  "role": "officer",
  "isActive": true
}

### Register/Create Emergency Responder
POST {{baseUrl}}/users
Content-Type: application/json

{
  "fullName": "EMT Responder",
  "email": "responder@example.com",
  "username": "emtresponder",
  "password": "Password123!",
  "phoneNumber": "+1234567892",
  "role": "emergency_responder",
  "isActive": true
}

### Register/Create Dispatcher
POST {{baseUrl}}/users
Content-Type: application/json

{
  "fullName": "Dispatch Coordinator",
  "email": "dispatcher@example.com",
  "username": "dispatcher",
  "password": "Password123!",
  "phoneNumber": "+1234567894",
  "role": "dispatcher",
  "isActive": true
}

### Register/Create Admin
POST {{baseUrl}}/users
Content-Type: application/json

{
  "fullName": "System Admin",
  "email": "admin@example.com",
  "username": "sysadmin",
  "password": "Password123!",
  "phoneNumber": "+1234567893",
  "role": "admin",
  "isActive": true
}

### Get all users
GET {{baseUrl}}/users
Authorization: Bearer {{accessToken}}

### Get user statistics
GET {{baseUrl}}/users/stats
Authorization: Bearer {{accessToken}}

### Get active users
GET {{baseUrl}}/users/active
Authorization: Bearer {{accessToken}}

### Get users by role
GET {{baseUrl}}/users/role/officer
Authorization: Bearer {{accessToken}}

### Get user by ID
GET {{baseUrl}}/users/{{userId}}
Authorization: Bearer {{accessToken}}

### Update user
PATCH {{baseUrl}}/users/{{userId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "fullName": "Jane Smith Updated",
  "phoneNumber": "+1234567893"
}

### Deactivate user
PATCH {{baseUrl}}/users/{{userId}}/deactivate
Authorization: Bearer {{accessToken}}

### Activate user
PATCH {{baseUrl}}/users/{{userId}}/activate
Authorization: Bearer {{accessToken}}

### Delete user
DELETE {{baseUrl}}/users/{{userId}}
Authorization: Bearer {{accessToken}}


### ==============================================
### ACCIDENTS ENDPOINTS
### ==============================================
### Create accident
POST {{baseUrl}}/accidents
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "description": "Two vehicle collision",
  "severity": "moderate",
  "status": "reported"
}

### Create accident report directly
POST {{baseUrl}}/accidents/report
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "accidentId": "{{accidentId}}",
  "reportData": {}
}

### Get all accidents
GET {{baseUrl}}/accidents
Authorization: Bearer {{accessToken}}

### Get accident by report number
GET {{baseUrl}}/accidents/report/ACC-20260129-001
Authorization: Bearer {{accessToken}}

### Get accidents by status
GET {{baseUrl}}/accidents/status/pending
Authorization: Bearer {{accessToken}}

### Get accidents by officer
GET {{baseUrl}}/accidents/officer/{{userId}}
Authorization: Bearer {{accessToken}}

### Get accidents by user ID
GET {{baseUrl}}/accidents/user/{{userId}}
Authorization: Bearer {{accessToken}}

### Get accident statistics
GET {{baseUrl}}/accidents/statistics
Authorization: Bearer {{accessToken}}

### Get accident by ID
GET {{baseUrl}}/accidents/{{accidentId}}
Authorization: Bearer {{accessToken}}

### Update accident
PATCH {{baseUrl}}/accidents/{{accidentId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "description": "Updated description",
  "severity": "severe"
}

### Assign officer to accident
PATCH {{baseUrl}}/accidents/{{accidentId}}/assign-officer
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "officerId": "{{userId}}"
}

### Update accident status
PATCH {{baseUrl}}/accidents/{{accidentId}}/status
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "status": "in_progress"
}

### Delete accident
DELETE {{baseUrl}}/accidents/{{accidentId}}
Authorization: Bearer {{accessToken}}


### ==============================================
### AI ENDPOINTS
### ==============================================
### Analyze accident with AI
POST {{baseUrl}}/ai/analyze-accident
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "accidentId": "{{accidentId}}",
  "description": "Collision at intersection"
}

### Generate accident report with AI
POST {{baseUrl}}/ai/generate-report
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "accidentId": "{{accidentId}}",
  "includeAnalysis": true
}

### Extract text from image
POST {{baseUrl}}/ai/extract-text
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "imageUrl": "https://storage.example.com/license_plate.jpg"
}

### Classify accident severity
POST {{baseUrl}}/ai/classify-severity
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "description": "Single vehicle collision with guardrail"
}

### Get AI insights for accident
GET {{baseUrl}}/ai/insights/{{accidentId}}
Authorization: Bearer {{accessToken}}


### ==============================================
### DISPATCH ENDPOINTS
### ==============================================
### Manual dispatch emergency services
POST {{baseUrl}}/dispatch/manual
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "accidentId": "{{accidentId}}",
  "userId": "{{userId}}",
  "severity": 75
}

### Get active dispatches
GET {{baseUrl}}/dispatch/active
Authorization: Bearer {{accessToken}}

### Get dispatches by accident
GET {{baseUrl}}/dispatch/accident/{{accidentId}}
Authorization: Bearer {{accessToken}}

### Get pending dispatches
GET {{baseUrl}}/dispatch/pending
Authorization: Bearer {{accessToken}}

### Get completed dispatches
GET {{baseUrl}}/dispatch/completed
Authorization: Bearer {{accessToken}}

### Get dispatch statistics
GET {{baseUrl}}/dispatch/statistics
Authorization: Bearer {{accessToken}}

### Send dispatch instruction to responder
POST {{baseUrl}}/dispatch/send-to-responder
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "accidentId": "{{accidentId}}",
  "responderId": "{{userId}}",
  "serviceType": "ambulance",
  "severity": 85,
  "incidentDescription": "Multiple vehicle collision with injuries",
  "instructions": "Bring triple immobilization kits. Potential spinal injuries.",
  "latitude": 37.7749,
  "longitude": -122.4194,
  "address": "123 Main St, Downtown",
  "reportNumber": "RPT-2026-001",
  "numberOfVehicles": 3,
  "numberOfInjuries": 4,
  "numberOfFatalities": 0,
  "weatherConditions": "Rainy",
  "roadConditions": "Wet, Low visibility",
  "priority": "high",
  "actionItems": ["Establish scene safety", "Triage patients", "Contact supervisor"]
}

### Get active dispatches for dispatcher
GET {{baseUrl}}/dispatch/dispatcher/active
Authorization: Bearer {{accessToken}}

### Get my assignments (Responder endpoint)
GET {{baseUrl}}/dispatch/my-assignments
Authorization: Bearer {{accessToken}}

### Get my assignments history (Responder endpoint)
GET {{baseUrl}}/dispatch/my-assignments/history
Authorization: Bearer {{accessToken}}

### Get dispatch details
GET {{baseUrl}}/dispatch/{{serviceId}}/details
Authorization: Bearer {{accessToken}}

### Acknowledge dispatch (Responder)
POST {{baseUrl}}/dispatch/{{serviceId}}/acknowledge
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "emergencyServiceId": "{{serviceId}}",
  "message": "Acknowledged - En route to scene. ETA 5 minutes."
}

### Update responder status (Responder)
PATCH {{baseUrl}}/dispatch/{{serviceId}}/status
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "status": "on_scene",
  "notes": "Arrived on scene. Multiple injuries confirmed. 2 patients requiring immediate transport.",
  "currentLatitude": 37.7749,
  "currentLongitude": -122.4194
}


